@model List<Cubo>

<h1 style="color:coral">Carrito</h1>
<p>
    <a asp-controller="Cubos" asp-action="Index">Volver a Cubos</a>
</p>

@if (Context.Session.GetString("IDSCUBOS") == null)
{
    <h2 style="color:green">No hay Cubos en el carrito</h2>
}
else
{
    <h4 style="color:red">@ViewData["PRECIOTOTAL"]</h4>
    <p>
        <a asp-controller="Cubos" asp-action="Carrito" asp-route-accion="comprar" class="btn btn-success">Comprar</a>
    </p>
}

@if (Model != null)
{
    <table class="table">
        <thead>
            <tr>
                <th>IdCubo</th>
                <th>Nombre</th>
                <th>Modelo</th>
                <th>Marca</th>
                <th>Imagen</th>
                <th>Precio</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.IdCubo</td>
                    <td>@item.Nombre</td>
                    <td>@item.Modelo</td>
                    <td>@item.Marca</td>
                    <td>
                        <img src="~/images/cubos/@item.Imagen" alt="@item.Nombre" style="max-width: 100px; max-height: 100px;" />
                    </td>
                    <td>@item.Precio</td>
                    <td>
                        <a asp-action="Carrito" asp-controller="Cubos" asp-route-ideliminar="@item.IdCubo" class="btn btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}